# NOT: src/frontend/public/build/ (Vite manifest + asset'leri) BİLEREK
# ignore EDİLMİYOR — .NET API bu derlenmiş çıktıyı servis ediyor ve bu ortamda
# Node kurulu olmadığından yeniden derlenemiyor. Build artefaktı repo'da kalmalı.

# ----- PHP / Laravel kaynağı (docs/paydopay-v4) -----
docs/paydopay-v4/vendor/
docs/paydopay-v4/storage/*.key
docs/paydopay-v4/storage/framework/cache/data/*
docs/paydopay-v4/storage/framework/sessions/*
docs/paydopay-v4/storage/framework/views/*
docs/paydopay-v4/storage/framework/testing/*
# Laravel dizin yapısını koruyan placeholder .gitignore dosyaları izlensin
!docs/paydopay-v4/storage/framework/**/.gitignore
docs/paydopay-v4/storage/logs/*
docs/paydopay-v4/bootstrap/cache/*.php
docs/paydopay-v4/.phpunit.result.cache
docs/paydopay-v4/auth.json

# ----- Runtime storage (repo kökü) -----
