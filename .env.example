# docker-compose için ortam değişkenleri.
# Kullanım: bu dosyayı `.env` olarak kopyalayıp değerleri doldurun (.env git'e girmez).

# --- Veritabanı ---
DB_NAME=tpanel_crm
DB_ROOT_PASSWORD=degistir_root_sifresi
DB_USER=tpanel
DB_PASSWORD=degistir_tpanel_sifresi

# --- Uygulama ---
# Marka/uygulama adı — tüm panel arayüzü, sayfa başlığı ve 2FA issuer'ı.
# Değiştirip `docker compose up -d` demek yeterli (frontend rebuild GEREKMEZ).
APP_NAME=TPanel
APP_URL=http://localhost:8080

# --- Opsiyonel: Telegram bildirimleri (boş = no-op) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_PAYROUTE_CHAT_ID=
# Webhook güvenlik token'ı (set-webhook ile aynı değer Telegram'a kaydedilir; rastgele uzun bir dize)
TELEGRAM_WEBHOOK_SECRET=
