  "developer": {
    "title": "{brand} Merchant API v1",
    "value": "Value",
    "field": "Field",
    "type": "Type",
    "required": "Required",
    "description": "Description",
    "meaning": "Meaning",
    "body_params": "Body Parameters",
    "example_response": "Example Response",
    "sections": {
      "overview": {
        "title": "Overview",
        "body": "{brand} Merchant API v1 is an HMAC-signed REST API that lets merchants submit deposit and withdrawal requests, query their status, and receive callbacks. All endpoints accept and return JSON."
      },
      "auth": {
        "title": "Authentication",
        "body": "Every request must include three custom headers. apiKey is the public identifier, apiSecret is the signing key and is never sent over the wire. The server recomputes the HMAC-SHA256 signature from the body and headers and verifies it. Requests with a timestamp outside ±5 minutes are rejected (replay protection).",
        "headers_title": "Required Headers",
        "h_api_key": "Merchant API Key (from panel)",
        "h_timestamp": "Unix seconds (±5 min drift allowed)",
        "h_signature": "hex( hmac_sha256(apiSecret, signed_payload) )",
        "signature_title": "Signature Formula",
        "signature_body": "Body hash + signed payload + HMAC-SHA256:",
        "example_title": "Sample Code"
      },
      "deposit": {
        "title": "Create Deposit Request",
        "body": "Opens a new deposit request. Redirect the player to the pay_url returned in the response; the player chooses a bank and completes the payment. The final result is POSTed to your callback_url; the player is redirected to successRedirectUrl or failRedirectUrl based on the outcome.",
        "f_order_id": "Unique order identifier on the merchant side",
        "f_amount": "Deposit amount in TRY (within merchant min/max)",
        "f_player_id": "Player identifier on the merchant side",
        "f_name": "Player full name",
        "f_callback": "Server-to-server URL where the result will be POSTed",
        "f_success_url": "URL the player is redirected to on successful payment",
        "f_fail_url": "URL the player is redirected to on rejection/cancel",
        "response_note": "The response contains pay_url. Redirect the player to it; {brand} handles the rest."
      },
      "deposit_h2h": {
        "title": "Deposit (H2H — Direct IBAN)",
        "body": "Host-to-host method. No pay URL is opened — the first available IBAN is returned directly in the response, and the player makes the transfer from the merchant's own screen. successRedirectUrl/failRedirectUrl are not required. The result is still POSTed to your callback_url.",
        "response_note": "The response returns IBAN details under data.bank. Display this IBAN on your own payment screen. If no suitable account is available, 503 is returned."
      },
      "withdraw": {
        "title": "Create Withdrawal Request",
        "body": "Opens a withdrawal request to the IBAN provided by the player. Approval/rejection happens in the panel; the result is delivered via callback.",
        "f_amount": "Withdrawal amount in TRY",
        "f_iban": "26-character IBAN starting with TR"
      },
      "banks": {
        "title": "Available IBAN List",
        "body": "Returns bank accounts eligible for the given amount. Does not create a transaction; list only.",
        "f_amount": "Deposit amount in TRY"
      },
      "transaction": {
        "title": "Query Transaction Status",
        "body": "Returns the current status of a deposit/withdrawal by order_id (or u_id).",
        "states_title": "States",
        "states_intro": "The data.status field shows the stage of the request. Possible values:",
        "state_pending_title": "pending",
        "state_pending_desc": "Request received; the player hasn't paid yet, or the payment hasn't been processed by the panel. status_code = 0 or 1. Still in progress.",
        "state_processing_title": "processing",
        "state_processing_desc": "An operator has claimed the request and is verifying the payment. status_code = 2. Still in progress — not a final state.",
        "state_approved_title": "approved",
        "state_approved_desc": "Approved and callback delivered. status_code = 3. Successful — final state.",
        "state_rejected_title": "rejected",
        "state_rejected_desc": "Rejected (payment not found, duplicate request, etc.). status_code = 4. Failed — final state.",
        "polling_tip": "You may poll every 5-10 seconds until a final state (approved/rejected) is reached, but the most reliable way to receive the final result is the POST sent to your callback_url."
      },
      "callback": {
        "title": "Callback (Webhook)",
        "body": "When the panel approves or rejects the request, {brand} POSTs to your callback_url. Verify each request using the hash in the body. Respond with HTTP 200 and a body of 'OK' or empty.",
        "outcomes_title": "Callback Outcomes",
        "outcome_approved_title": "Successful (approved)",
        "outcome_approved_desc": "code = 200, status = true. Request approved; you may credit the balance. invest.status in the database is 3.",
        "outcome_rejected_title": "Failed (rejected)",
        "outcome_rejected_desc": "code = 201, status = false. Request rejected; the reason is returned in the message field (e.g. payment not found). invest.status in the database is 4.",
        "outcome_pending_note": "No callback is sent during pending/processing stages. The callback is only triggered after a final result (3 or 4)."
      },
      "postman": {
        "title": "Postman Collection",
        "body": "Download the JSON below and import it into Postman. Set api_key and api_secret as collection variables; the HMAC signature is generated automatically for each request.",
        "download": "Download Postman Collection"
      },
      "errors": {
        "title": "Error Codes",
        "body": "The API uses standard HTTP status codes. Error messages are returned in the response message field.",
        "h_200": "Success",
        "h_401": "Authentication failed (apiKey/timestamp/signature)",
        "h_403": "Forbidden (account passive, blacklist, etc.)",
        "h_404": "Not found",
        "h_409": "Conflict (duplicate order_id, pending order)",
        "h_410": "Endpoint removed (legacy v0 API)",
        "h_422": "Validation error (amount out of range, invalid IBAN, etc.)",
        "h_500": "Server error"
      }
    }
  }
}
